+<!DOCTYPE html>
+<html lang="zh-Hant">
+<head>
+    <meta charset="UTF-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1.0">
+    <title>Local Control Panel</title>
+    <style>
+        :root {
+            color-scheme: light;
+            --bg: #f3efe7;
+            --panel: #fffaf1;
+            --ink: #1d1d1f;
+            --muted: #5c5c63;
+            --line: #d6cab7;
+            --accent: #b76e32;
+            --accent-strong: #8c4d17;
+        }
+        body {
+            margin: 0;
+            font-family: "Segoe UI", "Noto Sans TC", sans-serif;
+            background: linear-gradient(180deg, #f8f3ea 0%, var(--bg) 100%);
+            color: var(--ink);
+        }
+        main {
+            max-width: 960px;
+            margin: 0 auto;
+            padding: 24px;
+        }
+        h1 {
+            margin: 0 0 8px;
+            font-size: 28px;
+        }
+        p {
+            color: var(--muted);
+        }
+        .grid {
+            display: grid;
+            gap: 16px;
+            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
+        }
+        .panel {
+            background: var(--panel);
+            border: 1px solid var(--line);
+            border-radius: 10px;
+            padding: 18px;
+            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
+        }
+        label {
+            display: block;
+            font-size: 14px;
+            color: var(--muted);
+            margin-bottom: 8px;
+        }
+        select, button {
+            width: 100%;
+            font-size: 15px;
+            padding: 10px 12px;
+            border-radius: 8px;
+            border: 1px solid var(--line);
+            box-sizing: border-box;
+        }
+        button {
+            cursor: pointer;
+            background: var(--accent);
+            border: none;
+            color: white;
+            font-weight: 600;
+        }
+        button:hover {
+            background: var(--accent-strong);
+        }
+        .announce-list {
+            display: grid;
+            gap: 10px;
+        }
+        .announce-item {
+            display: flex;
+            gap: 10px;
+            align-items: start;
+            border: 1px solid var(--line);
+            border-radius: 8px;
+            padding: 10px;
+            background: white;
+        }
+        .announce-item input {
+            margin-top: 3px;
+        }
+        .meta {
+            font-size: 13px;
+            color: var(--muted);
+        }
+        .status {
+            margin-top: 12px;
+            min-height: 24px;
+            font-size: 14px;
+            color: var(--muted);
+        }
+        .actions {
+            display: grid;
+            gap: 12px;
+        }
+    </style>
+</head>
+<body>
+    <main>
+        <h1>Persona / Skin / Announce Control</h1>
+        <p>這個頁面只管理角色設定、Live2D 皮膚，以及主動播報項目，不直接修改大前端打包程式。</p>
+
+        <div class="grid">
+            <section class="panel">
+                <label for="personaSelect">Persona</label>
+                <select id="personaSelect"></select>
+                <div class="meta" id="personaMeta"></div>
+            </section>
+
+            <section class="panel">
+                <label for="skinSelect">Skin</label>
+                <select id="skinSelect"></select>
+                <div class="meta" id="skinMeta"></div>
+            </section>
+        </div>
+
+        <section class="panel" style="margin-top:16px;">
+            <label>Announce Sources</label>
+            <div id="announceList" class="announce-list"></div>
+        </section>
+
+        <section class="panel" style="margin-top:16px;">
+            <div class="actions">
+                <button id="applyButton">Apply Changes</button>
+                <button id="refreshButton" type="button">Reload State</button>
+            </div>
+            <div class="status" id="status">Loading…</div>
+        </section>
+    </main>
+
+    <script>
+        const statusEl = document.getElementById("status");
+        const personaSelect = document.getElementById("personaSelect");
+        const skinSelect = document.getElementById("skinSelect");
+        const announceList = document.getElementById("announceList");
+        const personaMeta = document.getElementById("personaMeta");
+        const skinMeta = document.getElementById("skinMeta");
+
+        let latestCatalog = null;
+
+        function setStatus(text, isError = false) {
+            statusEl.textContent = text;
+            statusEl.style.color = isError ? "#a12626" : "#5c5c63";
+        }
+
+        function checkboxValues() {
+            return Array.from(document.querySelectorAll("input[data-announce-id]:checked"))
+                .map((node) => node.dataset.announceId);
+        }
+
+        function renderCatalog(payload) {
+            latestCatalog = payload;
+
+            personaSelect.innerHTML = "";
+            for (const item of payload.catalogs.personas) {
+                const opt = document.createElement("option");
+                opt.value = item.id;
+                opt.textContent = item.label;
+                personaSelect.appendChild(opt);
+            }
+
+            skinSelect.innerHTML = "";
+            for (const item of payload.catalogs.skins) {
+                const opt = document.createElement("option");
+                opt.value = item.id;
+                opt.textContent = item.label;
+                skinSelect.appendChild(opt);
+            }
+
+            personaSelect.value = payload.state.selected_persona_id;
+            skinSelect.value = payload.state.selected_skin_id;
+            personaMeta.textContent = payload.persona.character_name + " / " + payload.persona.speaker_name;
+            skinMeta.textContent = payload.skin.live2d_model_name;
+
+            announceList.innerHTML = "";
+            for (const item of payload.catalogs.announces) {
+                const wrap = document.createElement("label");
+                wrap.className = "announce-item";
+                const checked = payload.state.enabled_announce_ids.includes(item.id) ? "checked" : "";
+                wrap.innerHTML = `
+                    <input type="checkbox" data-announce-id="${item.id}" ${checked}>
+                    <div>
+                        <div>${item.label}</div>
+                        <div class="meta">${item.provider} / abs ${item.threshold_abs_usdt} / pct ${item.threshold_pct}%</div>
+                    </div>
+                `;
+                announceList.appendChild(wrap);
+            }
+        }
+
+        async function loadState() {
+            setStatus("Loading…");
+            try {
+                const res = await fetch("/local-control/catalog");
+                const data = await res.json();
+                renderCatalog(data);
+                setStatus("State loaded.");
+            } catch (err) {
+                setStatus("Failed to load state: " + err, true);
+            }
+        }
+
+        async function applyState() {
+            setStatus("Applying changes…");
+            try {
+                const res = await fetch("/local-control/state", {
+                    method: "PUT",
+                    headers: { "Content-Type": "application/json" },
+                    body: JSON.stringify({
+                        selected_persona_id: personaSelect.value,
+                        selected_skin_id: skinSelect.value,
+                        enabled_announce_ids: checkboxValues()
+                    })
+                });
+                const data = await res.json();
+                renderCatalog(data);
+                setStatus("Applied. Connected clients should receive the new persona / skin.");
+            } catch (err) {
+                setStatus("Failed to apply changes: " + err, true);
+            }
+        }
+
+        document.getElementById("applyButton").addEventListener("click", applyState);
+        document.getElementById("refreshButton").addEventListener("click", loadState);
+        personaSelect.addEventListener("change", () => {
+            if (!latestCatalog) return;
+            const item = latestCatalog.catalogs.personas.find((entry) => entry.id === personaSelect.value);
+            if (item) {
+                personaMeta.textContent = item.character_name + " / " + item.speaker_name;
+            }
+        });
+        skinSelect.addEventListener("change", () => {
+            if (!latestCatalog) return;
+            const item = latestCatalog.catalogs.skins.find((entry) => entry.id === skinSelect.value);
+            if (item) {
+                skinMeta.textContent = item.live2d_model_name;
+            }
+        });
+
+        loadState();
+    </script>
+</body>
+</html>
