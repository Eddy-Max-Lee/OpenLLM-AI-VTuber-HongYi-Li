+﻿from __future__ import annotations
+
+import json
+from pathlib import Path
+from typing import Any
+
+from .config_manager import validate_config
+
+
+WORKSPACE_ROOT = Path(__file__).resolve().parents[3]
+APP_CONFIG_ROOT = WORKSPACE_ROOT / "app_config"
+STATE_PATH = APP_CONFIG_ROOT / "state.json"
+PERSONAS_DIR = APP_CONFIG_ROOT / "personas"
+SKINS_DIR = APP_CONFIG_ROOT / "skins"
+ANNOUNCES_DIR = APP_CONFIG_ROOT / "announces"
+
+
+def _read_json(path: Path, default: Any):
+    if not path.exists():
+        return default
+    return json.loads(path.read_text(encoding="utf-8-sig"))
+
+
+def _write_json(path: Path, data: Any) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
+
+
+def load_state() -> dict[str, Any]:
+    return _read_json(
+        STATE_PATH,
+        {
+            "selected_persona_id": "hungyi_tutor",
+            "selected_skin_id": "mao_pro",
+            "enabled_announce_ids": ["btc_usdt"],
+        },
+    )
+
+
+def save_state(state: dict[str, Any]) -> dict[str, Any]:
+    normalized = {
+        "selected_persona_id": str(state.get("selected_persona_id", "hungyi_tutor")).strip(),
+        "selected_skin_id": str(state.get("selected_skin_id", "mao_pro")).strip(),
+        "enabled_announce_ids": sorted(
+            {
+                str(item).strip()
+                for item in state.get("enabled_announce_ids", [])
+                if str(item).strip()
+            }
+        ),
+    }
+    _write_json(STATE_PATH, normalized)
+    return normalized
+
+
+def _load_catalog(directory: Path) -> list[dict[str, Any]]:
+    items = []
+    if not directory.exists():
+        return items
+
+    for path in sorted(directory.glob("*.json")):
+        data = _read_json(path, {})
+        if data:
+            items.append(data)
+    return items
+
+
+def load_catalogs() -> dict[str, list[dict[str, Any]]]:
+    return {
+        "personas": _load_catalog(PERSONAS_DIR),
+        "skins": _load_catalog(SKINS_DIR),
+        "announces": _load_catalog(ANNOUNCES_DIR),
+    }
+
+
+def _catalog_map(items: list[dict[str, Any]]) -> dict[str, dict[str, Any]]:
+    return {
+        str(item.get("id", "")).strip(): item
+        for item in items
+        if str(item.get("id", "")).strip()
+    }
+
+
+def _text_block(title: str, value: Any) -> str:
+    if not value:
+        return ""
+    if isinstance(value, str):
+        text = value.strip()
+    else:
+        text = json.dumps(value, ensure_ascii=False, indent=2)
+    if not text:
+        return ""
+    return f"\n\n[{title}]\n{text}"
+
+
+def compose_vtuber_persona_prompt(persona: dict[str, Any]) -> str:
+    prompt = str(persona.get("vtuber_persona_prompt", "")).strip()
+    prompt += _text_block("Role core concept", persona.get("core_concept"))
+    prompt += _text_block("Deep memory", persona.get("deep_memory"))
+    prompt += _text_block("Persona restrictions and negative prompts", persona.get("negative_prompts"))
+    return prompt.strip()
+
+
+def resolve_selection() -> dict[str, Any]:
+    state = load_state()
+    catalogs = load_catalogs()
+
+    personas = _catalog_map(catalogs["personas"])
+    skins = _catalog_map(catalogs["skins"])
+    announces = _catalog_map(catalogs["announces"])
+
+    persona = personas.get(state["selected_persona_id"]) or next(iter(personas.values()), {})
+    skin = skins.get(state["selected_skin_id"]) or next(iter(skins.values()), {})
+    enabled_announce_ids = [
+        announce_id
+        for announce_id in state.get("enabled_announce_ids", [])
+        if announce_id in announces
+    ]
+
+    if persona and state.get("selected_persona_id") != persona.get("id"):
+        state["selected_persona_id"] = persona.get("id")
+    if skin and state.get("selected_skin_id") != skin.get("id"):
+        state["selected_skin_id"] = skin.get("id")
+    if enabled_announce_ids != state.get("enabled_announce_ids", []):
+        state["enabled_announce_ids"] = enabled_announce_ids
+    save_state(state)
+
+    return {
+        "state": state,
+        "catalogs": catalogs,
+        "persona": persona,
+        "skin": skin,
+        "enabled_announces": [announces[item] for item in enabled_announce_ids],
+    }
+
+
+def build_controlled_config(base_config) -> Any:
+    selected = resolve_selection()
+    persona = selected["persona"]
+    skin = selected["skin"]
+
+    config_dict = base_config.model_dump(by_alias=True)
+    character = config_dict["character_config"]
+
+    if persona:
+        persona_id = persona["id"]
+        skin_id = skin.get("id", "skin") if skin else "skin"
+        character["conf_name"] = f"{persona_id}_{skin_id}"
+        character["conf_uid"] = f"{persona_id}_{skin_id}"
+        character["character_name"] = persona.get(
+            "character_name",
+            character.get("character_name", "AI"),
+        )
+        persona_prompt = compose_vtuber_persona_prompt(persona)
+        if persona_prompt:
+            character["persona_prompt"] = persona_prompt
+
+    if skin:
+        if skin.get("live2d_model_name"):
+            character["live2d_model_name"] = skin["live2d_model_name"]
+        character["avatar"] = skin.get("avatar", character.get("avatar", ""))
+
+    return validate_config(config_dict)
