     router = APIRouter()
     ws_handler = WebSocketHandler(default_context_cache)
 
+    @router.post("/local/announce")
+    async def local_announce(data: dict):
+        """Generate TTS for local automation text and broadcast it to connected clients."""
+        text = str(data.get("text", "")).strip()
+        if not text:
+            return JSONResponse({"error": "text is required"}, status_code=400)
+
+        if not ws_handler.client_connections:
+            return JSONResponse({"error": "no connected clients"}, status_code=409)
+
+        file_name = f"announce_{datetime.now().strftime('%Y%m%d_%H%M%S')}_{str(uuid4())[:8]}"
+        audio_path = None
+        try:
+            audio_path = await default_context_cache.tts_engine.async_generate_audio(
+                text=text,
+                file_name_no_ext=file_name,
+            )
+            payload = prepare_audio_payload(
+                audio_path=audio_path,
+                display_text=DisplayText(text=text, name=data.get("name", "市場播報")),
+            )
+
+            sent = 0
+            stale_clients = []
+            for client_uid, websocket in ws_handler.client_connections.items():
+                try:
+                    await websocket.send_text(json.dumps(payload))
+                    await websocket.send_text(json.dumps({"type": "backend-synth-complete"}))
+                    sent += 1
+                except Exception as exc:
+                    logger.warning(f"Failed to send local announcement to {client_uid}: {exc}")
+                    stale_clients.append(client_uid)
+
+            for client_uid in stale_clients:
+                await ws_handler.handle_disconnect(client_uid)
+
+            return {"status": "ok", "sent": sent, "text": text}
+        except Exception as exc:
+            logger.error(f"Local announcement failed: {exc}")
+            return JSONResponse({"error": str(exc)}, status_code=500)
+        finally:
+            if audio_path:
+                default_context_cache.tts_engine.remove_file(audio_path)
+
     @router.websocket("/client-ws")
     async def websocket_endpoint(websocket: WebSocket):
         """WebSocket endpoint for client connections"""
