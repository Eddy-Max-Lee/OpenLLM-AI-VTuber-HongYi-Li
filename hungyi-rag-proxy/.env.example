# Proxy
PROXY_HOST=127.0.0.1
PROXY_PORT=8765

# RAG
HUNGYI_SKILL_PATH=..\hung-yi-lee-skill
RAG_LIMIT=6
RAG_TIMEOUT_SECONDS=20

# Upstream backend options:
# openai_compatible or ollama_native
UPSTREAM_MODE=openai_compatible

# OpenAI-compatible mode
UPSTREAM_BASE_URL=http://127.0.0.1:11434/v1
UPSTREAM_API_KEY=not-needed
UPSTREAM_MODEL=qwen2.5:latest

# Ollama native mode
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:latest

# Generation
TEMPERATURE=0.7
MAX_TOKENS=1200

